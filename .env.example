# =========================================================================
# Kost Tiga Dara — contoh environment variables
# Salin file ini menjadi .env lalu isi nilainya. JANGAN commit .env.
# =========================================================================

# ---- Turso (sumber data dashboard, menggantikan Google Sheets) ----
# Bila TURSO_DATABASE_URL diisi, /api/sheets & /api/db membaca dari Turso
# dan menghitung ulang kolom formula (server/compute.js).
TURSO_DATABASE_URL=libsql://nama-db-organisasi.turso.io
TURSO_AUTH_TOKEN=isi_token_turso_di_sini
# Untuk uji lokal tanpa cloud, bisa pakai file SQLite:
# TURSO_DATABASE_URL=file:./data/local.db

# ---- Auth / server ----
JWT_SECRET=ganti_dengan_string_acak_panjang
NODE_ENV=development
# PORT=5512

# ---- (Opsional) Google Sheets — hanya dipakai bila Turso TIDAK di-set,
#      atau untuk menjalankan server/dump-formulas.js (ekstrak rumus asli).
SHEETS_SPREADSHEET_ID=1-xXweqO9IO6s0EQqF0fc7EKSybvn5CUSD601-Dvj328
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ---- (Opsional) Upstash Redis untuk penyimpanan akun di host ephemeral ----
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
