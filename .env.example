# =========================================================================
# Kost Tiga Dara — contoh environment variables
# Salin file ini menjadi .env lalu isi nilainya. JANGAN commit .env.
# =========================================================================

# ---- Auth: Clerk (WAJIB) ----
# Login, register, lupa password — ditangani Clerk (server kita tidak pernah
# menyimpan/melihat password). Buat app gratis di https://clerk.com, lalu
# salin dari Clerk Dashboard → API Keys. Lihat README untuk setup lengkap
# (aktifkan Username, Email+Password, dan Webhook).
CLERK_PUBLISHABLE_KEY=pk_test_isi_dari_clerk_dashboard
CLERK_SECRET_KEY=sk_test_isi_dari_clerk_dashboard
# Clerk Dashboard → Webhooks → tambah endpoint {DOMAIN}/api/webhooks/clerk,
# event "user.created" → salin Signing Secret. WAJIB agar akun baru otomatis
# berstatus "pending" (menunggu approval Owner) alih-alih langsung bisa login.
CLERK_WEBHOOK_SIGNING_SECRET=whsec_isi_dari_clerk_dashboard
# Opsional: hanya perlu diisi jika App Clerk memakai domain production custom
# (bukan *.clerk.accounts.dev bawaan) — mempersempit Content-Security-Policy
# agar tidak wildcard. Nilai persis ada di Clerk Dashboard → Domains.
# CLERK_FRONTEND_API_ORIGIN=https://clerk.domain-anda.com

# ---- 2FA / TOTP (Google Authenticator) — KUSTOM, bukan Clerk ----
# MFA bawaan Clerk hanya ada di paket Pro berbayar. 2FA di dashboard ini
# diimplementasikan sendiri (server/server.js, pakai `speakeasy`) sebagai
# lapisan tambahan DI ATAS sesi Clerk. String acak panjang, WAJIB di produksi
# (tanpa ini, semua orang diminta ulang kode 2FA setiap kali server restart/deploy).
TOTP_STEPUP_SECRET=ganti_dengan_string_acak_panjang

# ---- Turso (sumber data dashboard, menggantikan Google Sheets) ----
# Bila TURSO_DATABASE_URL diisi, /api/sheets & /api/db membaca dari Turso
# dan menghitung ulang kolom formula (server/compute.js).
TURSO_DATABASE_URL=libsql://nama-db-organisasi.turso.io
TURSO_AUTH_TOKEN=isi_token_turso_di_sini
# Untuk uji lokal tanpa cloud, bisa pakai file SQLite:
# TURSO_DATABASE_URL=file:./data/local.db

# ---- Server ----
NODE_ENV=development
# PORT=5512

# ---- (Opsional, HANYA lokal) Google Sheets — dashboard TIDAK lagi punya
#      fallback ke Sheets saat runtime (Turso satu-satunya sumber). Var ini
#      cuma dipakai kalau menjalankan server/dump-formulas.js secara manual
#      (ekstrak rumus asli spreadsheet). JANGAN di-set di Vercel.
# SHEETS_SPREADSHEET_ID=1-xXweqO9IO6s0EQqF0fc7EKSybvn5CUSD601-Dvj328
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
