{
  "name": "kost-tiga-dara-dashboard",
  "version": "1.0.0",
  "private": true,
  "description": "Kost Tiga Dara management dashboard. Auth via Clerk (2FA/TOTP, forgot-password, email verification). Data via Turso.",
  "scripts": {
    "start": "node server/server.js",
    "dev": "node server/server.js",
    "setup:sheets": "node server/setup-sheets.js",
    "bootstrap:owner": "node server/bootstrap-owner.js",
    "recompute": "node server/recompute-turso.js",
    "recompute:commit": "node server/recompute-turso.js --commit",
    "dump:formulas": "node server/dump-formulas.js"
  },
  "engines": {
    "node": "22.x"
  },
  "dependencies": {
    "@clerk/express": "^2.1.41",
    "@libsql/client": "^0.14.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "googleapis": "^173.0.0",
    "jsonwebtoken": "^9.0.3",
    "speakeasy": "^2.0.0",
    "svix": "^1.96.1"
  }
}
